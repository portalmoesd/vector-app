DATABASE_URL=postgres://user:password@localhost:5432/vector_portal
DATABASE_SSL_MODE=auto
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
WORKFLOW_UPLOAD_MAX_MB=50
ADMIN_UPLOAD_MAX_MB=50
JSON_BODY_LIMIT_MB=10
GEOSTAT_TLS_MODE=no-verify
LOG_FORMAT=text
JWT_SECRET=change-me-to-a-random-secret
PORT=3000
CORS_ORIGINS=https://your-production-domain.example
ALLOW_DEFAULT_SEED_USERS=false
NODE_ENV=production
