{
  "name": "vector-portal",
  "version": "1.0.0",
  "description": "Document approval workflow system for the Ministry of Economy of Georgia",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "dev": "node --watch server/index.js",
    "test": "node --test \"server/**/*.test.js\" \"frontend/**/*.test.js\"",
    "migrate": "node -e \"require('./server/migrate').runMigrations().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "check": "npm test && node scripts/check-syntax.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "sanitize-html": "^2.17.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.3",
    "swagger-ui-express": "^5.0.1"
  }
}
